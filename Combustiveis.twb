          <datasource-dependencies datasource='federated.01r2s9o0avvedm119w1u81y52ycc'>
            <column datatype='real' name='[Barril US$]' role='measure' type='quantitative' />
            <column caption='Governo_Novo' datatype='string' name='[Calculation_2474262645788674]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='case YEAR([DATA])&#10;    WHEN 2001 THEN &apos;FHC&apos;&#10;    WHEN 2002 THEN &apos;FHC&apos;&#10;    WHEN 2003 THEN &apos;Lula 1&apos;&#10;    WHEN 2004 THEN &apos;Lula 1&apos;&#10;    WHEN 2005 THEN &apos;Lula 1&apos;&#10;    WHEN 2006 THEN &apos;Lula 1&apos;&#10;    WHEN 2007 THEN &apos;Lula 2&apos;&#10;    WHEN 2008 THEN &apos;Lula 2&apos;&#10;    WHEN 2009 THEN &apos;Lula 2&apos;&#10;    WHEN 2010 THEN &apos;Lula 2&apos;&#10;    WHEN 2011 THEN &apos;Dilma 1&apos;&#10;    WHEN 2012 THEN &apos;Dilma 1&apos;&#10;    WHEN 2013 THEN &apos;Dilma 1&apos;&#10;    WHEN 2014 THEN &apos;Dilma 1&apos;&#10;    WHEN 2015 THEN &apos;Dilma 2&apos;&#10;    WHEN 2016 THEN&#10;        if month([DATA]) &lt;= 4 THEN&#10;            &apos;Dilma 2&apos;&#10;        ELSE&#10;            &apos;Temer&apos;&#10;        END&#10;    WHEN 2017 THEN &apos;Temer&apos;&#10;    WHEN 2018 THEN &apos;Temer&apos;&#10;    WHEN 2019 THEN &apos;Bolsonaro&apos;&#10;    WHEN 2020 THEN &apos;Bolsonaro&apos;&#10;    WHEN 2021 THEN &apos;Bolsonaro&apos;&#10;    WHEN 2022 THEN &apos;Bolsonaro&apos;&#10;    WHEN 2023 THEN &apos;Lula 3&apos;&#10;    WHEN 2024 THEN &apos;Lula 3&apos;&#10;    WHEN 2025 THEN &apos;Lula 3&apos;&#10;    WHEN 2026 THEN &apos;Lula 3&apos;&#10;ELSE &quot;Outro&quot;&#10;END' />
            </column>
            <column caption='GLP Kg' datatype='real' name='[Calculation_4207296623636480]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[GLP]/13' />
            </column>
            <column caption='Data' datatype='date' name='[DATA]' role='dimension' type='ordinal' />
            <column caption='Etanol Hidratado' datatype='real' name='[ETANOL HIDRATADO]' role='measure' type='quantitative' />
            <column caption='Gasolina Comum' datatype='real' name='[GASOLINA COMUM]' role='measure' type='quantitative' />
            <column datatype='real' name='[GLP]' role='measure' type='quantitative' />
            <column datatype='real' name='[US$]' role='measure' type='quantitative' />
